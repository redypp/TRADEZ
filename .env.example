# IBKR Connection (via TWS or IB Gateway) — only needed if using IBKR
IBKR_HOST=127.0.0.1
IBKR_PORT=7497           # 7497 = TWS paper | 7496 = TWS live | 4002 = Gateway paper | 4001 = Gateway live
IBKR_CLIENT_ID=1

# Tradovate API credentials (get from tradovate.com → API Management)
TRADOVATE_USERNAME=your_tradovate_username
TRADOVATE_PASSWORD=your_tradovate_password
TRADOVATE_APP_ID=your_app_id
TRADOVATE_APP_VERSION=1.0
TRADOVATE_DEVICE_ID=tradez-bot-001
TRADOVATE_CID=your_cid
TRADOVATE_SEC=your_secret_key

# Trading Mode
PAPER_TRADING=true

# Contracts to trade (IBKR futures symbols)
# MES = Micro E-mini S&P 500
# MNQ = Micro E-mini Nasdaq
# MGC = Micro Gold
SYMBOLS=MES,MGC

# Exchange and currency
EXCHANGE=CME
CURRENCY=USD

# Timeframe for strategy (in minutes)
TIMEFRAME=60

# Risk Settings
RISK_PER_TRADE=0.02
MAX_OPEN_POSITIONS=3
MAX_DAILY_DRAWDOWN=0.10

# Telegram Alerts
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Multi-LLM Strategy Selector ─────────────────────────────────────────────
# Set to true to enable AI-driven strategy selection (Claude + GPT-4 + Grok ensemble)
# Leave false to use rule-based BRT → ORB routing only
LLM_SELECTOR_ENABLED=false

# Anthropic (Claude) — orchestrator model, makes the final strategy decision
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (GPT-4o-mini) — macro/quantitative analyst
# Get key: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key

# xAI (Grok) — real-time X/Twitter sentiment + live news
# Get key: https://console.x.ai
XAI_API_KEY=your_xai_api_key

# Minimum LLM confidence to override rule-based routing (default: 0.60)
LLM_MIN_CONFIDENCE=0.60
