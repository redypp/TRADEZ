// ═══════════════════════════════════════════════════════════════════════════
// MES Break & Retest Strategy
// Chart: MES1! (or ES1!)  |  Timeframe: 1H
//
// Logic:
//   1. Track PDH/PDL and 20-bar swing levels as key price levels
//   2. Confirm a BREAK: close exceeds level + buffer, with decisive body size
//   3. Watch for a RETEST: price returns to ±0.25×ATR of broken level
//   4. Enter on CONFIRMATION candle: close > open, close > level,
//      EMA20 aligned, ADX ≥ 25, RSI 35-75, session 10:00-15:00 ET
//   5. SL = min(retest candle low, broken level) − 0.30×ATR
//   6. TP = 2:1 R:R
//
// Chart shows:
//   • Blue line       — EMA20 (trend alignment)
//   • Green step line — PDH (Previous Day High)
//   • Red step line   — PDL (Previous Day Low)
//   • Orange dots     — 20-bar Swing High
//   • Purple dots     — 20-bar Swing Low
//   • Aqua line       — Active broken level (while waiting for retest)
//   • Teal background — "Waiting for retest" bars
//   • ▲ arrow         — Long entry
//   • ✕ marker        — Exit (SL or TP)
//   • Top-right table — Live indicator values + current state
// ═══════════════════════════════════════════════════════════════════════════

//@version=6
strategy("MES Break and Retest", shorttitle="MES BRT", overlay=true, initial_capital=3000, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.cash_per_contract, commission_value=0.85, slippage=2, currency=currency.USD, calc_on_every_tick=false, max_bars_back=1000)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────
grp_ind  = "Indicators"
grp_brt  = "Break & Retest Parameters"
grp_risk = "Risk Management"
grp_sess = "Session Filter (ET)"
grp_vis  = "Visuals"

// Indicators
atr_len   = input.int(14, "ATR Period",          minval=5,  maxval=30,  group=grp_ind)
ema_len   = input.int(20, "EMA Period",          minval=5,  maxval=50,  group=grp_ind)
adx_len   = input.int(14, "ADX Period",          minval=5,  maxval=30,  group=grp_ind)
swing_len = input.int(20, "Swing Window (bars)", minval=5,  maxval=50,  group=grp_ind)

// B&R parameters
adx_min  = input.int  (25,   "Min ADX (25 = trending)",        minval=10, maxval=50,  group=grp_brt)
rsi_min  = input.int  (35,   "Min RSI for longs",              minval=10, maxval=50,  group=grp_brt)
rsi_max  = input.int  (75,   "Max RSI for longs",              minval=55, maxval=90,  group=grp_brt)
lev_tol  = input.float(0.25, "Retest Zone Width (×ATR)",       minval=0.05, step=0.05, group=grp_brt)
brk_buf  = input.float(0.15, "Break Buffer (×ATR)",            minval=0.05, step=0.05, group=grp_brt)
body_min = input.float(0.35, "Min Break Candle Body (×ATR)",   minval=0.05, step=0.05, group=grp_brt)
max_wait = input.int  (12,   "Max Bars to Wait for Retest",    minval=3,  maxval=30,  group=grp_brt)

// Risk
risk_pct = input.float(2.0,  "Risk Per Trade (%)",  minval=0.1, maxval=10, step=0.5, group=grp_risk)
sl_buf   = input.float(0.30, "SL Buffer (×ATR)",    minval=0.05, step=0.05,           group=grp_risk)
tp_rr    = input.float(2.0,  "Take Profit R:R",     minval=1.0, step=0.5,             group=grp_risk)

// Session (ET)
sess_start = input.int(10, "Entry allowed from (hour ET)", minval=0, maxval=23, group=grp_sess)
sess_end   = input.int(15, "Entry blocked after (hour ET)", minval=0, maxval=23, group=grp_sess)

// Visuals
show_pdh    = input.bool(true, "Show PDH/PDL lines",            group=grp_vis)
show_swing  = input.bool(true, "Show Swing High/Low dots",      group=grp_vis)
show_ema    = input.bool(true, "Show EMA20",                    group=grp_vis)
show_watch  = input.bool(true, "Highlight 'Waiting Retest'",    group=grp_vis)
show_table  = input.bool(true, "Show info table (top right)",   group=grp_vis)

// ─────────────────────────────────────────────────────────────────────────────
// INDICATORS
// ─────────────────────────────────────────────────────────────────────────────
atr_val             = ta.atr(atr_len)
ema20               = ta.ema(close, ema_len)
[_, _, adx_val]     = ta.dmi(adx_len, adx_len)
rsi_val             = ta.rsi(close, 14)
vol_ma              = ta.sma(volume, 20)

// ─────────────────────────────────────────────────────────────────────────────
// PDH / PDL  (previous completed day's high/low)
// request.security with [1] on Daily = yesterday's value, no lookahead bias
// ─────────────────────────────────────────────────────────────────────────────
pdh = request.security(syminfo.tickerid, "D", high[1])
pdl = request.security(syminfo.tickerid, "D", low[1])

// ─────────────────────────────────────────────────────────────────────────────
// SWING LEVELS  (N-bar rolling high/low, shifted 1 bar to avoid lookahead)
// ─────────────────────────────────────────────────────────────────────────────
swing_hi = ta.highest(high, swing_len)[1]
swing_lo = ta.lowest (low,  swing_len)[1]

// ─────────────────────────────────────────────────────────────────────────────
// FILTERS
// ─────────────────────────────────────────────────────────────────────────────
// Session (converts bar time to ET)
et_hour    = hour(time, "America/New_York")
in_session = et_hour >= sess_start and et_hour < sess_end

// Volume: break candle should have above-average volume (skip if data unavailable)
vol_ok = volume >= 1.2 * vol_ma or volume == 0 or na(vol_ma)

// ─────────────────────────────────────────────────────────────────────────────
// BREAK & RETEST STATE MACHINE
// ─────────────────────────────────────────────────────────────────────────────
var string brt_state     = "NEUTRAL"
var float  brt_level     = na
var string brt_ltype     = ""
var int    brt_break_bar = 0

// Derived thresholds for this bar
_tol      = lev_tol  * atr_val
_buf      = brk_buf  * atr_val
_body_req = body_min * atr_val

// Candle body size
_body_long = close - open

// ── NEUTRAL: scan for a valid level break ──────────────────────────────────
// PDH break (highest priority)
_pdh_break = not na(pdh) and close > pdh + _buf and _body_long >= _body_req and vol_ok

// Swing break — only if swing is not coincident with PDH (dedup)
_swing_near_pdh = not na(pdh) and math.abs(swing_hi - pdh) < atr_val * 0.5
_swing_break    = not na(swing_hi) and close > swing_hi + _buf and _body_long >= _body_req and vol_ok and not _swing_near_pdh

if brt_state == "NEUTRAL" and in_session and strategy.position_size == 0
    if _pdh_break
        brt_state     := "WATCHING_LONG"
        brt_level     := pdh
        brt_ltype     := "PDH"
        brt_break_bar := bar_index
    else if _swing_break
        brt_state     := "WATCHING_LONG"
        brt_level     := swing_hi
        brt_ltype     := "SWING"
        brt_break_bar := bar_index

// ── WATCHING_LONG: look for retest and confirmation ───────────────────────
if brt_state == "WATCHING_LONG"
    _bars_waited = bar_index - brt_break_bar

    // Timeout — no retest arrived in time
    if _bars_waited > max_wait
        brt_state := "NEUTRAL"
        brt_level := na
        brt_ltype := ""

    else
        _in_zone     = low <= brt_level + _tol and close >= brt_level - _tol
        _above_level = close > brt_level
        _ema_ok      = close > ema20
        _adx_ok      = adx_val >= adx_min
        _rsi_ok      = rsi_val > rsi_min and rsi_val < rsi_max
        _bull_bar    = close > open

        // Failed retest: price closes decisively below the broken level
        if close < brt_level - _tol
            brt_state := "NEUTRAL"
            brt_level := na
            brt_ltype := ""

        // All confluences met → enter long
        else if _in_zone and in_session and _above_level and _ema_ok and _adx_ok and _rsi_ok and _bull_bar and strategy.position_size == 0
            _sl_candle = low       - sl_buf * atr_val
            _sl_level  = brt_level - sl_buf * atr_val
            _sl_price  = math.min(_sl_candle, _sl_level)
            _risk      = close - _sl_price

            if _risk > 0
                _tp_price = close + tp_rr * _risk

                // Dynamic position sizing: risk_pct of equity / (risk × point value)
                // MES point value = $5; change to 50 if using ES1!
                _point_val = syminfo.pointvalue
                _contracts = math.max(1, math.floor(strategy.equity * (risk_pct / 100) / (_risk * _point_val)))

                strategy.entry(
                    id      = "B&R Long",
                    direction = strategy.long,
                    qty     = _contracts,
                    comment = brt_ltype + " retest @ " + str.tostring(math.round(brt_level, 2))
                )
                strategy.exit(
                    id        = "B&R Exit",
                    from_entry = "B&R Long",
                    stop      = _sl_price,
                    limit     = _tp_price,
                    comment   = "SL " + str.tostring(math.round(_sl_price, 2)) +
                                " / TP " + str.tostring(math.round(_tp_price, 2))
                )

                // Reset state
                brt_state := "NEUTRAL"
                brt_level := na
                brt_ltype := ""

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────

// EMA20
plot(show_ema ? ema20 : na, "EMA 20",
     color=color.new(color.blue, 30), linewidth=1)

// PDH / PDL — step lines (update at start of each new day)
plot(show_pdh ? pdh : na, "PDH",
     color=color.new(color.lime, 10), style=plot.style_stepline, linewidth=2)
plot(show_pdh ? pdl : na, "PDL",
     color=color.new(color.red, 10),  style=plot.style_stepline, linewidth=2)

// Swing high/low dots
plot(show_swing ? swing_hi : na, "Swing Hi",
     color=color.new(color.orange, 20), linewidth=1, style=plot.style_circles)
plot(show_swing ? swing_lo : na, "Swing Lo",
     color=color.new(color.fuchsia, 20), linewidth=1, style=plot.style_circles)

// Active broken level line (while watching for retest)
plot(brt_state == "WATCHING_LONG" ? brt_level : na, "Broken Level (watching)",
     color=color.new(color.aqua, 0), linewidth=2, style=plot.style_line)

// Background highlight: "waiting for retest" bars
bgcolor(show_watch and brt_state == "WATCHING_LONG"
        ? color.new(color.teal, 88) : na,
        title="Waiting Retest")

// ─────────────────────────────────────────────────────────────────────────────
// INFO TABLE  (top-right corner)
// ─────────────────────────────────────────────────────────────────────────────
if show_table and barstate.islast
    var table t = table.new(
        position     = position.top_right,
        columns      = 2,
        rows         = 10,
        border_width = 1,
        border_color = color.new(color.gray, 60),
        bgcolor      = color.new(color.black, 75)
    )

    // Header
    table.cell(t, 0, 0, "MES Break & Retest",
               text_color=color.white, bgcolor=color.new(color.navy, 20),
               text_size=size.small)
    table.cell(t, 1, 0, "", bgcolor=color.new(color.navy, 20))

    // State
    _s_col = brt_state == "WATCHING_LONG" ? color.aqua : color.gray
    table.cell(t, 0, 1, "State",   text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 1, brt_state, text_color=_s_col,       text_size=size.small)

    // Broken level
    table.cell(t, 0, 2, "Level",   text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 2,
               brt_state == "WATCHING_LONG" ? brt_ltype + " " + str.tostring(math.round(brt_level, 2)) : "–",
               text_color=color.aqua, text_size=size.small)

    // ADX
    _adx_col = adx_val >= adx_min ? color.lime : color.red
    table.cell(t, 0, 3, "ADX",     text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 3,
               str.tostring(math.round(adx_val, 1)) + (adx_val >= adx_min ? "  ✓" : "  ✗"),
               text_color=_adx_col, text_size=size.small)

    // RSI
    _rsi_ok_now = rsi_val > rsi_min and rsi_val < rsi_max
    _rsi_col    = _rsi_ok_now ? color.lime : color.orange
    table.cell(t, 0, 4, "RSI",     text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 4,
               str.tostring(math.round(rsi_val, 1)) + (_rsi_ok_now ? "  ✓" : "  ✗"),
               text_color=_rsi_col, text_size=size.small)

    // EMA20
    _ema_col = close > ema20 ? color.lime : color.red
    table.cell(t, 0, 5, "EMA20",   text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 5,
               str.tostring(math.round(ema20, 2)) + (close > ema20 ? "  ↑" : "  ↓"),
               text_color=_ema_col, text_size=size.small)

    // ATR
    table.cell(t, 0, 6, "ATR",     text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 6, str.tostring(math.round(atr_val, 2)),
               text_color=color.white, text_size=size.small)

    // PDH / PDL
    table.cell(t, 0, 7, "PDH",     text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 7, str.tostring(math.round(pdh, 2)),
               text_color=color.lime, text_size=size.small)

    table.cell(t, 0, 8, "PDL",     text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 8, str.tostring(math.round(pdl, 2)),
               text_color=color.red, text_size=size.small)

    // Session
    _sess_col = in_session ? color.lime : color.red
    table.cell(t, 0, 9, "Session", text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 9, in_session ? "OPEN  ✓" : "CLOSED",
               text_color=_sess_col, text_size=size.small)
