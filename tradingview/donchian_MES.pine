//@version=5
strategy(
     title       = "TRADEZ — Donchian Breakout (MES Long Only)",
     shorttitle  = "TRADEZ MES",
     overlay     = true,
     initial_capital = 3000,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 2,
     commission_type   = strategy.commission.cash_per_contract,
     commission_value  = 0.85,
     calc_on_every_tick = false
)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
entryPeriod = input.int(20,  "Entry Period (Donchian)",  minval=5)
exitPeriod  = input.int(10,  "Exit Period (Trailing)",   minval=3)
atrPeriod   = input.int(20,  "ATR Period",               minval=5)
atrSL       = input.float(2.0, "ATR Stop Multiplier",   minval=0.5, step=0.1)

// ─── DONCHIAN CHANNELS ────────────────────────────────────────────────────────
// Shift by 1 bar to avoid lookahead bias
dcUpper = ta.highest(high[1], entryPeriod)
dcLower = ta.lowest(low[1],   entryPeriod)
exitHigh = ta.highest(high[1], exitPeriod)
exitLow  = ta.lowest(low[1],   exitPeriod)

// ─── ATR FOR STOP ─────────────────────────────────────────────────────────────
atr = ta.atr(atrPeriod)

// ─── SIGNALS ──────────────────────────────────────────────────────────────────
longEntry  = close > dcUpper
longExit   = close < exitLow

// ─── STRATEGY LOGIC ───────────────────────────────────────────────────────────
var float stopPrice = na

if longEntry and strategy.position_size == 0
    stopPrice := close - atrSL * atr
    strategy.entry("Long", strategy.long)

if strategy.position_size > 0
    // Trail stop up as price moves in our favour
    stopPrice := math.max(stopPrice, close - atrSL * atr)
    strategy.exit("Exit", "Long", stop=stopPrice)

if longExit and strategy.position_size > 0
    strategy.close("Long", comment="Trail Exit")

// ─── PLOTS ────────────────────────────────────────────────────────────────────
plot(dcUpper,  "Entry Upper",  color=color.new(color.green, 20),  linewidth=2)
plot(dcLower,  "Entry Lower",  color=color.new(color.red,   20),  linewidth=1, style=plot.style_line)
plot(exitLow,  "Exit Low",     color=color.new(color.orange, 30), linewidth=1, style=plot.style_line)
plot(strategy.position_size > 0 ? stopPrice : na, "Stop Loss", color=color.red, linewidth=1, style=plot.style_cross)

// Highlight entry candles
bgcolor(longEntry and strategy.position_size == 0 ? color.new(color.green, 85) : na, title="Long Entry")
bgcolor(longExit  and strategy.position_size > 0  ? color.new(color.red,   85) : na, title="Trail Exit")

// ─── INFO TABLE ───────────────────────────────────────────────────────────────
var table info = table.new(position.top_right, 2, 4, border_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Strategy",  text_color=color.white, bgcolor=color.navy)
    table.cell(info, 1, 0, "TRADEZ MES", text_color=color.white, bgcolor=color.navy)
    table.cell(info, 0, 1, "Entry",     text_color=color.gray)
    table.cell(info, 1, 1, str.tostring(entryPeriod) + "-day breakout", text_color=color.gray)
    table.cell(info, 0, 2, "Exit",      text_color=color.gray)
    table.cell(info, 1, 2, str.tostring(exitPeriod)  + "-day trail",    text_color=color.gray)
    table.cell(info, 0, 3, "Stop",      text_color=color.gray)
    table.cell(info, 1, 3, str.tostring(atrSL) + "x ATR",              text_color=color.gray)
